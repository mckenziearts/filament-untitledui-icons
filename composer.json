  "description": "Untitledui icon pack for Filament Icons",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "Laravel",
    "Filament",
    "icons",
    "Untitledui"
  ],
  "authors": [
    {
      "role": "Developer",
      "name": "Arthur Monney",
      "email": "monneylobe@gmail.com"
    }
  ],
  "require": {
